{
  "hosting": {
    "public": "public_empty",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "treasury-committee",
          "region": "asia-northeast1"
        }
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9199
    },
    "firestore": {
      "port": 8181
    },
    "hosting": {
      "port": 5100
    },
    "ui": {
      "enabled": true,
      "port": 4100
    },
    "hub": {
      "port": 4510
    },
    "logging": {
      "port": 4610
    },
    "singleProjectMode": true,
    "exportOnExit": ".emulator-data",
    "import": ".emulator-data"
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
